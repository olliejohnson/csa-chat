<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="io.oliverj.chat.client.ui.ChatScreen">
  <grid id="27dc6" binding="contentView" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <component id="2ef7b" class="javax.swing.JTextField" binding="messageBox">
        <constraints border-constraint="South"/>
        <properties/>
      </component>
      <scrollpane id="43fdf" binding="scrollPane">
        <constraints border-constraint="Center"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="1bd8f" class="javax.swing.JTextArea" binding="chatBox">
            <constraints/>
            <properties>
              <editable value="false"/>
            </properties>
          </component>
        </children>
      </scrollpane>
    </children>
  </grid>
</form>
