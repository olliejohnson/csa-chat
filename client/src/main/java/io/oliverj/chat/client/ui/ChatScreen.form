<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="io.oliverj.chat.client.ui.ChatScreen">
  <grid id="27dc6" binding="contentView" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <component id="2ef7b" class="javax.swing.JTextField" binding="messageBox">
        <constraints border-constraint="South"/>
        <properties/>
      </component>
      <component id="89335" class="javax.swing.JLabel" binding="chatView">
        <constraints border-constraint="West"/>
        <properties>
          <autoscrolls value="true"/>
          <text value=""/>
          <verticalAlignment value="1"/>
          <verticalTextPosition value="1"/>
        </properties>
      </component>
    </children>
  </grid>
</form>
